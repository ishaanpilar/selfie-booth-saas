# --- Database -----------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/selfie_booth?schema=public"

# --- BetterAuth -----------------------------------------------------------
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"

# --- Public app URL (client-side) -----------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Supabase Storage -------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="selfie-booth-assets"

# --- Transactional email (optional; falls back to console logging) --------
RESEND_API_KEY=""
EMAIL_FROM="Selfie Booth <no-reply@selfiebooth.app>"
